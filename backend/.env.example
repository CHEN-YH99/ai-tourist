# Backend Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Node Environment
NODE_ENV=development

# Server Configuration
PORT=3000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# MongoDB Configuration
# Development: mongodb://localhost:27017/travel-assistant
# Production: mongodb+srv://username:password@cluster.mongodb.net/travel-assistant?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/travel-assistant

# JWT Configuration
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-here-change-in-production

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Logging Configuration
LOG_LEVEL=debug

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_REQUESTS=5
AI_RATE_LIMIT_MAX_REQUESTS=10

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Database Configuration (for Docker Compose)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=password
